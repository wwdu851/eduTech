# Copy to .env and fill in real values. Never commit .env.

NODE_ENV=development
PORT=4000

# Neo4j Aura (or local bolt://localhost:7687)
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=xxxxxxxx
NEO4J_PASSWORD=your-password-here

# Min 8 chars locally; min 32 chars when NODE_ENV=production
JWT_SECRET=change-me-use-openssl-rand-hex-32-for-production

GEMINI_API_KEY=your-gemini-api-key

# Browser origin for CORS (required when NODE_ENV=production)
# Local dev: http://localhost:3000
# After Vercel deploy: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000
